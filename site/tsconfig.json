{
	"compilerOptions": {
		"target": "ES2024",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": [
			"ES2024",
			"DOM",
			"DOM.Iterable"
		],
		"strict": true,
		"noEmit": true,
		"useDefineForClassFields": false,
		"isolatedModules": true,
		"skipLibCheck": true
	},
	"include": [
		"src/**/*.ts"
	]
}